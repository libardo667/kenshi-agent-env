{
  "$defs": {
    "ClickAction": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "click",
          "default": "click",
          "title": "Kind",
          "type": "string"
        },
        "x": {
          "title": "X",
          "type": "number"
        },
        "y": {
          "title": "Y",
          "type": "number"
        },
        "space": {
          "$ref": "#/$defs/CoordinateSpace",
          "default": "normalized"
        },
        "button": {
          "$ref": "#/$defs/MouseButton",
          "default": "left"
        },
        "clicks": {
          "default": 1,
          "maximum": 3,
          "minimum": 1,
          "title": "Clicks",
          "type": "integer"
        },
        "hold_seconds": {
          "default": 0.0,
          "maximum": 0.5,
          "minimum": 0.0,
          "title": "Hold Seconds",
          "type": "number"
        },
        "interval_seconds": {
          "default": 0.08,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Interval Seconds",
          "type": "number"
        }
      },
      "required": [
        "x",
        "y"
      ],
      "title": "ClickAction",
      "type": "object"
    },
    "Condition": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/ConditionKind"
        },
        "path": {
          "anyOf": [
            {
              "$ref": "#/$defs/ConditionPath"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "operator": {
          "$ref": "#/$defs/ConditionOperator"
        },
        "expected": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expected"
        },
        "target_id": {
          "anyOf": [
            {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Id"
        },
        "max_age_seconds": {
          "exclusiveMinimum": 0.0,
          "maximum": 300.0,
          "title": "Max Age Seconds",
          "type": "number"
        },
        "required_capabilities": {
          "items": {
            "type": "string"
          },
          "maxItems": 20,
          "title": "Required Capabilities",
          "type": "array"
        }
      },
      "required": [
        "kind",
        "operator",
        "max_age_seconds"
      ],
      "title": "Condition",
      "type": "object"
    },
    "ConditionKind": {
      "enum": [
        "field",
        "capability",
        "telemetry_fresh"
      ],
      "title": "ConditionKind",
      "type": "string"
    },
    "ConditionOperator": {
      "enum": [
        "equals",
        "not_equals",
        "less_than",
        "less_than_or_equal",
        "greater_than",
        "greater_than_or_equal",
        "contains",
        "exists"
      ],
      "title": "ConditionOperator",
      "type": "string"
    },
    "ConditionPath": {
      "enum": [
        "control_mode",
        "telemetry_stale",
        "telemetry.game.loaded",
        "telemetry.game.paused",
        "telemetry.game.speed_multiplier",
        "telemetry.game.elapsed_minutes",
        "telemetry.game.money",
        "telemetry.game.location_name",
        "telemetry.game.day",
        "telemetry.game.hour",
        "telemetry.game.minute",
        "telemetry.ui.active_screen",
        "telemetry.ui.modal_open",
        "telemetry.ui.dialogue_open",
        "telemetry.ui.dialogue_target_id",
        "telemetry.ui.dialogue_option_count",
        "telemetry.ui.dialogue_option_0",
        "telemetry.ui.tooltip_visible",
        "telemetry.ui.tooltip_text",
        "telemetry.ui.context_menu_open",
        "telemetry.ui.selected_character_id",
        "telemetry.ui.selected_character_count",
        "telemetry.active_shop_trader_count",
        "telemetry.native_control.available",
        "telemetry.native_control.last_command_sequence",
        "telemetry.native_control.last_command",
        "telemetry.native_control.last_result",
        "telemetry.native_control.last_target",
        "telemetry.native_control.last_target_id",
        "selected.alive",
        "selected.conscious",
        "selected.down",
        "selected.in_combat",
        "selected.position.x",
        "selected.position.y",
        "selected.position.z",
        "selected.movement_speed",
        "selected.hunger",
        "selected.bleeding_rate",
        "selected.food_items",
        "selected.first_aid_kits",
        "selected.current_goal",
        "target.disposition",
        "target.distance",
        "target.visible",
        "target.conscious",
        "target.has_vendor_list",
        "target.is_squad_leader",
        "target.has_dialogue",
        "target.shop_inventory_owner",
        "target.talk_task_available",
        "game.pause",
        "game.speed",
        "game.time",
        "game.money",
        "game.location",
        "camera.position",
        "squad.basic",
        "squad.hunger",
        "squad.health",
        "squad.inventory",
        "ui.modal",
        "ui.inventory",
        "ui.dialogue",
        "ui.dialogue.target",
        "ui.dialogue.options",
        "ui.tooltip",
        "nearby.characters",
        "nearby.visible_entities",
        "nearby.roles",
        "nearby.shop_owners",
        "control.approach_vendor",
        "identity.stable_handles"
      ],
      "title": "ConditionPath",
      "type": "string"
    },
    "ControlMode": {
      "enum": [
        "interface_only",
        "native_assisted"
      ],
      "title": "ControlMode",
      "type": "string"
    },
    "CoordinateSpace": {
      "enum": [
        "normalized",
        "client",
        "screen"
      ],
      "title": "CoordinateSpace",
      "type": "string"
    },
    "HotkeyAction": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "hotkey",
          "default": "hotkey",
          "title": "Kind",
          "type": "string"
        },
        "keys": {
          "items": {
            "type": "string"
          },
          "maxItems": 5,
          "minItems": 2,
          "title": "Keys",
          "type": "array"
        },
        "hold_seconds": {
          "default": 0.04,
          "maximum": 5.0,
          "minimum": 0.0,
          "title": "Hold Seconds",
          "type": "number"
        }
      },
      "required": [
        "keys"
      ],
      "title": "HotkeyAction",
      "type": "object"
    },
    "IdempotencyPolicy": {
      "enum": [
        "at_most_once",
        "safe_to_retry"
      ],
      "title": "IdempotencyPolicy",
      "type": "string"
    },
    "InterruptPolicy": {
      "enum": [
        "cancel_on_reflex"
      ],
      "title": "InterruptPolicy",
      "type": "string"
    },
    "KeyAction": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "key",
          "default": "key",
          "title": "Kind",
          "type": "string"
        },
        "key": {
          "maxLength": 32,
          "minLength": 1,
          "title": "Key",
          "type": "string"
        },
        "hold_seconds": {
          "default": 0.04,
          "maximum": 5.0,
          "minimum": 0.0,
          "title": "Hold Seconds",
          "type": "number"
        }
      },
      "required": [
        "key"
      ],
      "title": "KeyAction",
      "type": "object"
    },
    "MouseButton": {
      "enum": [
        "left",
        "right",
        "middle"
      ],
      "title": "MouseButton",
      "type": "string"
    },
    "MoveCursorAction": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "move_cursor",
          "default": "move_cursor",
          "title": "Kind",
          "type": "string"
        },
        "x": {
          "title": "X",
          "type": "number"
        },
        "y": {
          "title": "Y",
          "type": "number"
        },
        "space": {
          "$ref": "#/$defs/CoordinateSpace",
          "default": "normalized"
        }
      },
      "required": [
        "x",
        "y"
      ],
      "title": "MoveCursorAction",
      "type": "object"
    },
    "NoopAction": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "noop",
          "default": "noop",
          "title": "Kind",
          "type": "string"
        },
        "reason": {
          "default": "No action required.",
          "title": "Reason",
          "type": "string"
        }
      },
      "title": "NoopAction",
      "type": "object"
    },
    "ObservationPolicy": {
      "enum": [
        "after_action",
        "until_terminal"
      ],
      "title": "ObservationPolicy",
      "type": "string"
    },
    "PauseAction": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "pause",
          "default": "pause",
          "title": "Kind",
          "type": "string"
        },
        "paused": {
          "default": true,
          "title": "Paused",
          "type": "boolean"
        }
      },
      "title": "PauseAction",
      "type": "object"
    },
    "PlanStep": {
      "additionalProperties": false,
      "properties": {
        "step_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$",
          "title": "Step Id",
          "type": "string"
        },
        "action": {
          "anyOf": [
            {
              "$ref": "#/$defs/NoopAction"
            },
            {
              "$ref": "#/$defs/StopAction"
            },
            {
              "$ref": "#/$defs/PauseAction"
            },
            {
              "$ref": "#/$defs/SetSpeedAction"
            },
            {
              "$ref": "#/$defs/WaitAction"
            },
            {
              "$ref": "#/$defs/KeyAction"
            },
            {
              "$ref": "#/$defs/HotkeyAction"
            },
            {
              "$ref": "#/$defs/MoveCursorAction"
            },
            {
              "$ref": "#/$defs/ClickAction"
            },
            {
              "$ref": "#/$defs/ScrollAction"
            },
            {
              "$ref": "#/$defs/SkillAction"
            }
          ],
          "title": "Action"
        },
        "preconditions": {
          "items": {
            "$ref": "#/$defs/Condition"
          },
          "maxItems": 12,
          "minItems": 1,
          "title": "Preconditions",
          "type": "array"
        },
        "success_conditions": {
          "items": {
            "$ref": "#/$defs/Condition"
          },
          "maxItems": 12,
          "minItems": 1,
          "title": "Success Conditions",
          "type": "array"
        },
        "failure_conditions": {
          "items": {
            "$ref": "#/$defs/Condition"
          },
          "maxItems": 12,
          "title": "Failure Conditions",
          "type": "array"
        },
        "timeout_seconds": {
          "exclusiveMinimum": 0.0,
          "maximum": 60.0,
          "title": "Timeout Seconds",
          "type": "number"
        },
        "retry_budget": {
          "default": 0,
          "maximum": 2,
          "minimum": 0,
          "title": "Retry Budget",
          "type": "integer"
        },
        "idempotency": {
          "$ref": "#/$defs/IdempotencyPolicy",
          "default": "at_most_once"
        },
        "on_success": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "On Success"
        },
        "on_failure": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "On Failure"
        },
        "interrupt_policy": {
          "$ref": "#/$defs/InterruptPolicy",
          "default": "cancel_on_reflex"
        },
        "observation_policy": {
          "$ref": "#/$defs/ObservationPolicy",
          "default": "until_terminal"
        }
      },
      "required": [
        "step_id",
        "action",
        "preconditions",
        "success_conditions",
        "timeout_seconds"
      ],
      "title": "PlanStep",
      "type": "object"
    },
    "RiskBudget": {
      "additionalProperties": false,
      "properties": {
        "max_pointer_actions": {
          "maximum": 32,
          "minimum": 0,
          "title": "Max Pointer Actions",
          "type": "integer"
        },
        "max_purchase_actions": {
          "maximum": 8,
          "minimum": 0,
          "title": "Max Purchase Actions",
          "type": "integer"
        },
        "max_native_assisted_actions": {
          "maximum": 8,
          "minimum": 0,
          "title": "Max Native Assisted Actions",
          "type": "integer"
        }
      },
      "required": [
        "max_pointer_actions",
        "max_purchase_actions",
        "max_native_assisted_actions"
      ],
      "title": "RiskBudget",
      "type": "object"
    },
    "ScrollAction": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "scroll",
          "default": "scroll",
          "title": "Kind",
          "type": "string"
        },
        "x": {
          "title": "X",
          "type": "number"
        },
        "y": {
          "title": "Y",
          "type": "number"
        },
        "space": {
          "$ref": "#/$defs/CoordinateSpace",
          "default": "normalized"
        },
        "notches": {
          "maximum": 8,
          "minimum": -8,
          "title": "Notches",
          "type": "integer"
        }
      },
      "required": [
        "x",
        "y",
        "notches"
      ],
      "title": "ScrollAction",
      "type": "object"
    },
    "SetSpeedAction": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "set_speed",
          "default": "set_speed",
          "title": "Kind",
          "type": "string"
        },
        "speed": {
          "enum": [
            1,
            2,
            3
          ],
          "title": "Speed",
          "type": "integer"
        }
      },
      "required": [
        "speed"
      ],
      "title": "SetSpeedAction",
      "type": "object"
    },
    "SkillAction": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "skill",
          "default": "skill",
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "maxLength": 80,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "args": {
          "items": {
            "$ref": "#/$defs/SkillArgument"
          },
          "maxItems": 20,
          "title": "Args",
          "type": "array"
        }
      },
      "required": [
        "name"
      ],
      "title": "SkillAction",
      "type": "object"
    },
    "SkillArgument": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "maxLength": 80,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Value"
        }
      },
      "required": [
        "name",
        "value"
      ],
      "title": "SkillArgument",
      "type": "object"
    },
    "StopAction": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "stop",
          "default": "stop",
          "title": "Kind",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "reason"
      ],
      "title": "StopAction",
      "type": "object"
    },
    "WaitAction": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "wait",
          "default": "wait",
          "title": "Kind",
          "type": "string"
        },
        "seconds": {
          "maximum": 60.0,
          "minimum": 0.0,
          "title": "Seconds",
          "type": "number"
        }
      },
      "required": [
        "seconds"
      ],
      "title": "WaitAction",
      "type": "object"
    },
    "WorldStateRevision": {
      "additionalProperties": false,
      "properties": {
        "telemetry_sequence": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Telemetry Sequence"
        },
        "frame_sequence": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Frame Sequence"
        },
        "capability_epoch": {
          "default": 0,
          "minimum": 0,
          "title": "Capability Epoch",
          "type": "integer"
        },
        "observed_at_monotonic": {
          "minimum": 0.0,
          "title": "Observed At Monotonic",
          "type": "number"
        }
      },
      "title": "WorldStateRevision",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "plan_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,95}$",
      "title": "Plan Id",
      "type": "string"
    },
    "plan_version": {
      "default": 1,
      "minimum": 1,
      "title": "Plan Version",
      "type": "integer"
    },
    "objective": {
      "maxLength": 1000,
      "minLength": 1,
      "title": "Objective",
      "type": "string"
    },
    "control_mode": {
      "$ref": "#/$defs/ControlMode"
    },
    "based_on_revision": {
      "$ref": "#/$defs/WorldStateRevision"
    },
    "assumptions": {
      "items": {
        "$ref": "#/$defs/Condition"
      },
      "maxItems": 12,
      "minItems": 1,
      "title": "Assumptions",
      "type": "array"
    },
    "steps": {
      "items": {
        "$ref": "#/$defs/PlanStep"
      },
      "maxItems": 8,
      "minItems": 1,
      "title": "Steps",
      "type": "array"
    },
    "entry_step_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$",
      "title": "Entry Step Id",
      "type": "string"
    },
    "max_actions": {
      "maximum": 16,
      "minimum": 1,
      "title": "Max Actions",
      "type": "integer"
    },
    "max_wall_seconds": {
      "exclusiveMinimum": 0.0,
      "maximum": 120.0,
      "title": "Max Wall Seconds",
      "type": "number"
    },
    "max_game_seconds": {
      "exclusiveMinimum": 0.0,
      "maximum": 3600.0,
      "title": "Max Game Seconds",
      "type": "number"
    },
    "risk_budget": {
      "$ref": "#/$defs/RiskBudget"
    }
  },
  "required": [
    "schema_version",
    "plan_id",
    "objective",
    "control_mode",
    "based_on_revision",
    "assumptions",
    "steps",
    "entry_step_id",
    "max_actions",
    "max_wall_seconds",
    "max_game_seconds",
    "risk_budget"
  ],
  "title": "PlanEnvelope",
  "type": "object"
}
