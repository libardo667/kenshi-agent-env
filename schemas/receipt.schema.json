{
  "$defs": {
    "ClickAction": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "click",
          "default": "click",
          "title": "Kind",
          "type": "string"
        },
        "x": {
          "title": "X",
          "type": "number"
        },
        "y": {
          "title": "Y",
          "type": "number"
        },
        "space": {
          "$ref": "#/$defs/CoordinateSpace",
          "default": "normalized"
        },
        "button": {
          "$ref": "#/$defs/MouseButton",
          "default": "left"
        },
        "clicks": {
          "default": 1,
          "maximum": 3,
          "minimum": 1,
          "title": "Clicks",
          "type": "integer"
        },
        "hold_seconds": {
          "default": 0.0,
          "maximum": 0.5,
          "minimum": 0.0,
          "title": "Hold Seconds",
          "type": "number"
        },
        "interval_seconds": {
          "default": 0.08,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Interval Seconds",
          "type": "number"
        }
      },
      "required": [
        "x",
        "y"
      ],
      "title": "ClickAction",
      "type": "object"
    },
    "Condition": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/ConditionKind"
        },
        "path": {
          "anyOf": [
            {
              "$ref": "#/$defs/ConditionPath"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "operator": {
          "$ref": "#/$defs/ConditionOperator"
        },
        "expected": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expected"
        },
        "target_id": {
          "anyOf": [
            {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Id"
        },
        "max_age_seconds": {
          "exclusiveMinimum": 0.0,
          "maximum": 300.0,
          "title": "Max Age Seconds",
          "type": "number"
        },
        "required_capabilities": {
          "items": {
            "type": "string"
          },
          "maxItems": 20,
          "title": "Required Capabilities",
          "type": "array"
        }
      },
      "required": [
        "kind",
        "operator",
        "max_age_seconds"
      ],
      "title": "Condition",
      "type": "object"
    },
    "ConditionEvaluation": {
      "additionalProperties": false,
      "properties": {
        "condition": {
          "$ref": "#/$defs/Condition"
        },
        "result": {
          "$ref": "#/$defs/ConditionResult"
        },
        "actual": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Actual"
        },
        "reason": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "condition",
        "result",
        "reason"
      ],
      "title": "ConditionEvaluation",
      "type": "object"
    },
    "ConditionKind": {
      "enum": [
        "field",
        "capability",
        "telemetry_fresh"
      ],
      "title": "ConditionKind",
      "type": "string"
    },
    "ConditionOperator": {
      "enum": [
        "equals",
        "not_equals",
        "less_than",
        "less_than_or_equal",
        "greater_than",
        "greater_than_or_equal",
        "contains"
      ],
      "title": "ConditionOperator",
      "type": "string"
    },
    "ConditionPath": {
