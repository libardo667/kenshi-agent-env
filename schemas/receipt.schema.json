    },
    "ConditionResult": {
      "enum": [
        "true",
        "false",
        "unknown",
        "unavailable",
        "stale"
      ],
      "title": "ConditionResult",
      "type": "string"
    },
    "ControlMode": {
      "enum": [
        "interface_only",
        "native_assisted"
      ],
      "title": "ControlMode",
      "type": "string"
    },
    "CoordinateSpace": {
      "enum": [
        "normalized",
        "client",
        "screen"
      ],
      "title": "CoordinateSpace",
      "type": "string"
    },
    "HotkeyAction": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "hotkey",
          "default": "hotkey",
          "title": "Kind",
          "type": "string"
        },
        "keys": {
          "items": {
            "type": "string"
          },
          "maxItems": 5,
          "minItems": 2,
          "title": "Keys",
          "type": "array"
        },
        "hold_seconds": {
          "default": 0.04,
          "maximum": 5.0,
          "minimum": 0.0,
          "title": "Hold Seconds",
          "type": "number"
        }
      },
      "required": [
        "keys"
      ],
      "title": "HotkeyAction",
      "type": "object"
    },
    "InputBoundaryDecision": {
      "description": "Outcome of the final revalidation performed inside the acquired input lease.",
      "enum": [
        "not_required",
        "revalidated",
        "rejected"
      ],
      "title": "InputBoundaryDecision",
      "type": "string"
    },
    "InputBoundaryReport": {
      "additionalProperties": false,
      "description": "Evidence from the final fence that runs after the input lease is acquired.\n\nValidation performed before a polite input lease can become obsolete while\nthe lease is pending, so a sensitive action revalidates its typed plan\nconditions against the latest canonical revision immediately before the\nfirst primitive is emitted.",
      "properties": {
        "decision": {
          "$ref": "#/$defs/InputBoundaryDecision"
        },
        "reason": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "lease_wait_seconds": {
          "default": 0.0,
          "minimum": 0.0,
          "title": "Lease Wait Seconds",
          "type": "number"
        },
        "plan_id": {
          "anyOf": [
            {
              "maxLength": 96,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Plan Id"
        },
        "plan_version": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Plan Version"
        },
        "step_id": {
          "anyOf": [
            {
              "maxLength": 64,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Step Id"
        },
        "validated_revision": {
          "anyOf": [
            {
              "$ref": "#/$defs/WorldStateRevision"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "boundary_revision": {
          "anyOf": [
            {
              "$ref": "#/$defs/WorldStateRevision"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "evaluations": {
          "items": {
            "$ref": "#/$defs/ConditionEvaluation"
          },
          "maxItems": 24,
          "title": "Evaluations",
          "type": "array"
        }
      },
      "required": [
        "decision",
        "reason"
      ],
      "title": "InputBoundaryReport",
      "type": "object"
    },
    "KeyAction": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "key",
          "default": "key",
          "title": "Kind",
