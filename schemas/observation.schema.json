{
  "$defs": {
    "ActionOutcome": {
      "additionalProperties": false,
      "properties": {
        "step_index": {
          "minimum": 0,
          "title": "Step Index",
          "type": "integer"
        },
        "intent": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Intent",
          "type": "string"
        },
        "action": {
          "anyOf": [
            {
              "$ref": "#/$defs/NoopAction"
            },
            {
              "$ref": "#/$defs/StopAction"
            },
            {
              "$ref": "#/$defs/PauseAction"
            },
            {
              "$ref": "#/$defs/SetSpeedAction"
            },
            {
              "$ref": "#/$defs/WaitAction"
            },
            {
              "$ref": "#/$defs/KeyAction"
            },
            {
              "$ref": "#/$defs/HotkeyAction"
            },
            {
              "$ref": "#/$defs/MoveCursorAction"
            },
            {
              "$ref": "#/$defs/ClickAction"
            },
            {
              "$ref": "#/$defs/ScrollAction"
            },
            {
              "$ref": "#/$defs/SkillAction"
            }
          ],
          "title": "Action"
        },
        "executed": {
          "title": "Executed",
          "type": "boolean"
        },
        "receipt_message": {
          "default": "",
          "maxLength": 2000,
          "title": "Receipt Message",
          "type": "string"
        },
        "assessment": {
          "$ref": "#/$defs/ActionOutcomeAssessment"
        },
        "feedback": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Feedback",
          "type": "string"
        },
        "visual_change_fraction": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Visual Change Fraction"
        },
        "telemetry_changes": {
          "items": {
            "type": "string"
          },
          "maxItems": 30,
          "title": "Telemetry Changes",
          "type": "array"
        },
        "selected_character_name": {
          "anyOf": [
            {
              "maxLength": 200,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Selected Character Name"
        },
        "position_before": {
          "anyOf": [
            {
              "$ref": "#/$defs/Vec3"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "position_after": {
          "anyOf": [
            {
              "$ref": "#/$defs/Vec3"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "step_index",
        "intent",
        "action",
        "executed",
        "assessment",
        "feedback"
      ],
      "title": "ActionOutcome",
      "type": "object"
    },
    "ActionOutcomeAssessment": {
      "enum": [
        "changed",
        "no_op",
        "not_executed",
