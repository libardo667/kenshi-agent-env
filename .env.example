# Copy this file to .env and replace values locally.
# .env is ignored by Git; never commit or paste real secrets into logs or chat.

# Only needed for the OpenAI planner.
OPENAI_API_KEY=

# Only needed when selecting the OpenRouter planner.
OPENROUTER_API_KEY=

# Optional: override where the native plugin writes telemetry.
# Windows example:
# KENSHI_AGENT_TELEMETRY_DIR=C:\Users\you\AppData\Local\KenshiAgent

# Optional: override the model in config.
# KENSHI_AGENT_MODEL=gpt-5.6-luna
# KENSHI_AGENT_REASONING_EFFORT=low
# KENSHI_AGENT_OPENROUTER_MODEL=openai/gpt-5.6-luna
# KENSHI_AGENT_OPENROUTER_SORT=latency
